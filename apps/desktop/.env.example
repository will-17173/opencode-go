# ================================
# macOS 代码签名和公证配置
# ================================

# 方式 1: 使用 App Store Connect API Key（推荐）
# 在 https://appstoreconnect.apple.com/access/api 创建
APPLE_API_KEY=/path/to/AuthKey_ABC1234567.p8  # .p8 文件绝对路径
APPLE_API_KEY_ID=ABC1234567  # Key ID（10位字符）
APPLE_API_ISSUER=12345678-1234-1234-1234-123456789012  # Issuer ID（UUID）

# 方式 2: 使用 Apple ID + App-Specific Password（备用）
# APPLE_ID=your-apple-id@example.com
# APPLE_APP_SPECIFIC_PASSWORD=xxxx-xxxx-xxxx-xxxx  # 在 appleid.apple.com 生成

# Team ID（两种方式都需要，用于代码签名）
APPLE_TEAM_ID=TEAM1234567  # 10位 Team ID

# 证书名称（可选，自动从钥匙串读取）
# CSC_NAME="Developer ID Application: Your Name (TEAM1234567)"

# ================================
# Windows 代码签名配置
# ================================

CSC_LINK=/path/to/certificate.p12  # .p12 或 .pfx 文件绝对路径
CSC_KEY_PASSWORD=your-certificate-password  # 证书密码

# ================================
# 构建配置
# ================================

# 跳过签名（仅测试用）
# CSC_IDENTITY_AUTO_DISCOVERY=false
