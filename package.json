{
  "name": "opencode-monorepo",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "start": "npm run start -w opencode-go",
    "start:updater": "npm run start:updater -w opencode-go",
    "build": "npm run build -w opencode-go",
    "clean": "npm run clean -w opencode-go",
    "make": "npm run make -w opencode-go",
    "make:mac": "npm run make:mac -w opencode-go",
    "make:win": "npm run make:win -w opencode-go",
    "make:all": "npm run make:all -w opencode-go",
    "publish": "npm run publish -w opencode-go",
    "publish:mac": "npm run publish:mac -w opencode-go",
    "lint": "npm run lint -w opencode-go",
    "build:web": "npm run build -w opencode-go-web"
  }
}